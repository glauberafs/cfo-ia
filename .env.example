# Copie para .env na raiz do monorepo. NUNCA comite o .env real.

# Postgres (sobe com `docker compose up -d db`)
DATABASE_URL=postgresql+psycopg2://cfo:cfo@localhost:5432/cfo_ia

# JWT da API
JWT_SECRET=troque-este-segredo-em-producao
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Credenciais do APP na Pluggy (uma so para toda a plataforma).
# O item_id de cada conexao do usuario fica no banco, nao aqui.
PLUGGY_CLIENT_ID=
PLUGGY_CLIENT_SECRET=

# URL da API para o cliente web (Streamlit) apontar
API_URL=http://localhost:8000
